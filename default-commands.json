  "OpenWRT Router Automations": {
    "path": "AutoSec/scripts",
    "exec": "openssh",
    "command": "sshpass -p \"$PASSWORD\" ssh -nT \\\n-o StrictHostKeyChecking=no \\\n\"$USER@$HOST\" \\\n\"$REMOTE_COMMAND\"",
    "extras": [
      {
        "default": "root",
        "description": "The SSH user on the host.",
        "id": "735279",
        "name": "USER",
        "required": true,
        "flags": [
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "openwrt",
        "description": "The SSH host to connect to.",
        "id": "486044",
        "name": "HOST",
        "required": true,
        "flags": [
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "",
        "description": "SSH password.",
        "id": "829258",
        "name": "PASSWORD",
        "required": true,
        "flags": [
          "--password",
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "uci set wireless.radio0.disabled=0 && uci commit wireless && wifi reload",
        "description": "The command to run after sshing into the remote server.",
        "id": "708927",
        "name": "REMOTE_COMMAND",
        "required": true,
        "type": "SELECTABLE",
        "selectableOptions": {
          "Enable 5GHz": "uci set wireless.radio0.disabled=0 && uci commit wireless && wifi reload",
          "Disable 5GHz": "uci set wireless.radio0.disabled=1 && uci commit wireless && wifi reload",
          "/etc/init.d/network restart": "/etc/init.d/network restart",
          "reboot": "reboot",
          "logread": "logread",
          "ifdown wan && ifup wan": "ifdown wan && ifup wan",
          "wifi reload": "wifi reload",
          "etherwake -i br-lan AA:BB:CC:DD:EE:FF": "etherwake -i br-lan AA:BB:CC:DD:EE:FF"
        }
      }
    ],
    "id": "autopie.openwrt-router-automations"
  },
