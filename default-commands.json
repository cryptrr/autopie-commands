        "id": "862978",
        "name": "SCRIPT_NAME",
        "required": true,
        "type": "SELECTABLE",
        "selectableOptions": [
          "night_mode",
          "day_mode",
          "lights_off",
          "ambient_mode",
          "emergency"
        ]
      },
      {
        "default": "https://homeassistant.local/api/services/script/turn_on",
