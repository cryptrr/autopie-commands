  "Trigger Home Assistant": {
    "path": "",
    "exec": "httpx",
    "command": "httpx -m POST ${COOKIE_FILE:+--cookie-file $COOKIE_FILE} -d entity_id script.${SCRIPT_NAME} $URL",
    "extras": [
      {
        "default": "/storage/emulated/0/cookies.txt",
        "description": "The full path to cookie file.",
        "id": "829804",
        "name": "COOKIE_FILE",
        "required": true,
        "type": "STRING"
      },
      {
