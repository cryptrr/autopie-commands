  },
  "YT-DLP Download": {
    "path": "Download",
    "exec": "yt-dlp",
    "command": "yt-dlp \\\n  -o \"%(title).200B-${RAND}.%(ext)s\" \\\n  --no-mtime \\\n  -f \"bestvideo[height<=${MAX_QUALITY}]+bestaudio/best[height<=${MAX_QUALITY}]/best\" \\\n  ${COOKIE_JAR:+--cookies \"$COOKIE_JAR\"} \\\n  ${START_TIME:+--download-sections \"*${START_TIME}-${END_TIME:-inf}\"} \\\n  \"$INPUT_URL\"",
    "extras": [
      {
        "default": "1920",
        "description": "",
        "id": "969610",
        "name": "MAX_QUALITY",
        "required": true,
        "type": "SELECTABLE",
        "selectableOptions": {
          "1920": "1920",
          "1080": "1080",
          "720": "720",
          "480": "480",
          "2160": "2160",
          "1440": "1440"
        }
      },
      {
        "default": "00:00:00",
        "description": "",
        "id": "599983",
        "name": "START_TIME",
        "required": true,
        "type": "STRING"
      },
      {
        "default": "",
        "description": "",
        "id": "461479",
        "name": "END_TIME",
        "required": false,
        "type": "STRING"
      }
    ],
    "id": "autopie.yt-dlp-download"
  },
  "YT-DLP: Download as Audio": {
    "path": "Download",
    "exec": "yt-dlp",
    "command": "yt-dlp --no-mtime -x --audio-format ${FORMAT} \"${INPUT_URL}\"",
    "extras": [
      {
        "default": "mp3",
        "description": "Choose the format to convert to.",
        "id": "745322",
        "name": "FORMAT",
        "required": true,
        "type": "SELECTABLE",
        "selectableOptions": [
          "mp3",
          "m4a",
          "aac",
          "opus",
          "vorbis",
          "flac",
          "wav"
        ]
      }
    ],
    "id": "autopie.yt-dlp-download-as-audio"
  },
