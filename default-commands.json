  "Shutdown Remote Server": {
    "path": "AutoSec/scripts",
    "exec": "openssh",
    "command": "sshpass -p \"$PASSWORD\" \\\nssh -nT \\\n-o StrictHostKeyChecking=no \\\n\"$USER@$HOST\" \\\n\"echo '$PASSWORD' | sudo -S /sbin/shutdown -h now\"",
    "extras": [
      {
        "default": "",
        "description": "The SSH user on host.",
        "id": "735279",
        "name": "USER",
        "required": true,
        "flags": [
