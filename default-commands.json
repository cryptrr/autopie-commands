  "Change Volume on Mac": {
    "path": "AutoSec/scripts",
    "exec": "openssh",
    "command": "sshpass -p \"$PASSWORD\" ssh -nT \\\n-o StrictHostKeyChecking=no \\\n\"$USER@$HOST\" \\\n\"osascript -e \\\"set volume output volume ${VOLUME}\\\"\"",
    "extras": [
      {
        "default": "amal",
        "description": "The SSH user on the host.",
        "id": "735279",
        "name": "USER",
        "required": true,
        "flags": [
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "amals-mac-mini.lan",
        "description": "The SSH host to connect to.",
        "id": "486044",
        "name": "HOST",
        "required": true,
        "flags": [
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "",
        "description": "SSH password.",
        "id": "829258",
        "name": "PASSWORD",
        "required": true,
        "flags": [
          "--password",
          "--internal-config"
        ],
        "type": "STRING"
      },
      {
        "default": "0,50,100",
        "description": "Slider to set volume.",
        "id": "574538",
        "name": "VOLUME",
        "required": true,
        "flags": [
          "--int",
          "--realtime"
        ],
        "type": "SLIDER"
      }
    ],
    "id": "autopie.change-volume-on-mac"
  },
  "Change Volume on Mac - AutoFetch": {
    "id": "autopie.change-volume-on-mac-autofetch",
    "multiStage": true,
    "steps": [
      {
        "path": "AutoSec/scripts",
        "exec": "openssh",
        "command": "CURRENT_VOLUME=$(sshpass -p \"$PASSWORD\" ssh -nT \\\n-o StrictHostKeyChecking=no \\\n\"$USER@$HOST\" \\\n\"osascript -e \\\"output volume of (get volume settings)\\\"\")\nexport CURRENT_VOLUME\nexport SLIDER_OPTIONS=0,\"$CURRENT_VOLUME\",100",
        "extras": [
          {
            "default": "amal",
            "description": "The SSH user on the host.",
            "id": "735279",
            "name": "USER",
            "required": true,
            "flags": [
              "--internal-config"
            ],
            "type": "STRING"
          },
          {
            "default": "amals-mac-mini.lan",
            "description": "The SSH host to connect to.",
            "id": "486044",
            "name": "HOST",
            "required": true,
            "flags": [
              "--internal-config"
            ],
            "type": "STRING"
          },
          {
            "default": "",
            "description": "SSH password.",
            "id": "829258",
            "name": "PASSWORD",
            "required": true,
            "flags": [
              "--internal-config",
              "--password"
            ],
            "type": "STRING"
          }
        ]
      },
      {
        "path": "AutoSec/scripts",
        "exec": "openssh",
        "command": "sshpass -p \"$PASSWORD\" ssh -nT \\\n-o StrictHostKeyChecking=no \\\n\"$USER@$HOST\" \\\n\"osascript -e \\\"set volume output volume ${VOLUME}\\\"\"",
        "extras": [
          {
            "default": "$$SLIDER_OPTIONS",
            "description": "Slider to set volume.",
            "id": "574538",
            "name": "VOLUME",
            "required": true,
            "flags": [
              "--int",
              "--realtime"
            ],
            "type": "SLIDER"
          }
        ]
      }
    ]
  },
