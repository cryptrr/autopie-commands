      {
        "default": "libvpx-vp9",
        "description": "Choose vp9 for better file size. Choose vp8 for better support.",
        "id": "246920",
        "name": "CODEC",
        "required": false,
        "type": "SELECTABLE",
        "selectableOptions": [
          "libvpx-vp9",
          "libvpx"
