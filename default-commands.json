        "id": "202404",
        "name": "URL",
        "required": true,
        "type": "STRING"
      }
    ],
    "id": "autopie.trigger-home-assistant"
  },
  "Virus Check (VirusTotal)": {
    "path": "",
    "exec": "",
    "command": "set -euo pipefail\n\nif [[ ! -f \"$INPUT_FILE\" ]]; then\n    echo \"Usage: $0 <file>\"\n    exit 1\nfi\n\nHASH=$(sha256sum \"$INPUT_FILE\" | awk '{print $1}')\nURL=\"https://www.virustotal.com/gui/file/$HASH\"\n\necho \"SHA-256: $HASH\"\necho \"Opening: $URL\"\n\nam start \\\n    -a android.intent.action.VIEW \\\n    -d \"$URL\"",
    "flags": [
      "--show-loading-screen"
    ],
    "id": "autopie.virus-check-virustotal"
  },
  "Watermark Video": {
    "path": "",
    "exec": "ffmpeg",
    "command": "ffmpeg -i \"${INPUT_FILE}\" -i \"${WATERMARK_FILE}\" -filter_complex \"overlay=$( \\\n    case $POSITION in \\\n        TOP_LEFT) echo '10:10';; \\\n        TOP_RIGHT) echo 'W-w-10:10';; \\\n        BOTTOM_LEFT) echo '10:H-h-10';; \\\n        BOTTOM_RIGHT) echo 'W-w-10:H-h-10';; \\\n        CENTER) echo '(W-w)/2:(H-h)/2';; \\\n        *) echo 'W-w-10:10';; \\\n    esac)\" -codec:a copy \"${INPUT_FILE}-watermarked-${RAND}.mp4\"",
    "extras": [
      {
        "default": "",
        "description": "Full path to the watermark image.",
        "id": "368719",
        "name": "WATERMARK_FILE",
        "required": true,
        "type": "STRING"
      },
      {
        "default": "BOTTOM_RIGHT",
        "description": "Choose the position where you want to put the watermark.",
        "id": "819827",
        "name": "POSITION",
        "required": true,
        "type": "SELECTABLE",
        "selectableOptions": [
          "BOTTOM_RIGHT",
          "TOP_RIGHT",
          "TOP_LEFT",
          "BOTTOM_LEFT",
          "CENTER"
        ]
      }
    ],
    "id": "autopie.watermark-video"
  },
  "wCurl Download": {
    "path": "Download",
    "exec": "wcurl",
    "command": "wcurl ${FILE_NAME_EXTRA:+-o \"$FILE_NAME_EXTRA\"} \"$INPUT_URL\"",
