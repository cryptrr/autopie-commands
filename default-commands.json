  "Convert To WebM": {
    "path": "Downloads",
    "exec": "ffmpeg",
    "command": "ffmpeg -i \"${INPUT_FILE}\" -c:v libvpx-vp9 -crf 24 \"${INPUT_FILE}.webm\"",
    "extras": [
